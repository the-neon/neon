{
  "name": "neon",
  "version": "0.0.5",
  "private": true,
  "engines": {
    "node": ">= 24.0.0"
  },
  "repository": "git@github.com:the-neon/neon.git",
  "author": "stojce <stojce@me.com>",
  "license": "MIT",
  "bin": "./bin/neon.js",
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "husky"
    ]
  },
  "scripts": {
    "test": "jest --coverage",
    "clean": "rm -rf packages/*/lib",
    "build:core": "tsc -p ./packages/core",
    "build:dynamodb": "tsc -p ./packages/dynamodb",
    "build:validation": "tsc -p ./packages/validation",
    "build:pg": "tsc -p ./packages/pg",
    "build:mysql": "tsc -p ./packages/mysql",
    "build:gql": "tsc -p ./packages/gql",
    "build": "tsc --build tsconfig.json",
    "version:patch": "pnpm --workspace-concurrency=1 -r exec pnpm version patch",
    "version:minor": "pnpm --workspace-concurrency=1 -r exec pnpm version minor",
    "version:major": "pnpm --workspace-concurrency=1 -r exec pnpm version major",
    "publish": "pnpm clean && pnpm build && pnpm -r publish --access public --no-git-checks",
    "pretty": "prettier --write './packages/**/*.{yml,yaml,json,ts,tsx,js,jsx,scss,css,md,html}'"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/source-map-support": "^0.5.6",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^4.3.8",
    "jest": "^29.7.0",
    "lint-staged": "^10.5.4",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "packages/**/*.{yml,yaml,json,ts,tsx,js,jsx,scss,css,md,html}": [
      "prettier --write"
    ],
    "packages/**/*.ts": [
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "workspaces": [
    "packages/*"
  ]
}