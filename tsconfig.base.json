{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "outDir": "${configDir}/lib",
    "module": "commonjs",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "typeRoots": ["${configDir}/node_modules/@types"]
  },
  "exclude": ["node_modules", "${configDir}/lib", "typings/**", "**/*.test.*"]
}
