{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "composite": false,
    "outDir": "lib",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types"],
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "module": "preserve"
  },
  "exclude": ["node_modules", "lib", "typings/**", "**/*.test.*"]
}
